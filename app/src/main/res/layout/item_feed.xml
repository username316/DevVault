<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/feedCardRoot"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/lime">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <!-- Score pill -->
        <TextView
            android:id="@+id/textViewFeedScore"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:paddingHorizontal="14dp"
            android:gravity="center"
            android:text="↑ 0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/space_grotesk"
            android:textColor="@color/pill_text"
            android:background="@drawable/pill_bg_white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Author pill -->
        <TextView
            android:id="@+id/textViewFeedAuthor"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:paddingHorizontal="14dp"
            android:gravity="center"
            android:text="by —"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/space_grotesk"
            android:textColor="@color/pill_text"
            android:background="@drawable/pill_bg_white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/textViewFeedScore" />

        <!-- External link button -->
        <FrameLayout
            android:id="@+id/linkBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_dark"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="↗"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/textViewFeedTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Story title goes here"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/space_grotesk"
            android:textColor="@color/text_primary"
            android:letterSpacing="-0.02"
            android:ellipsize="end"
            android:maxLines="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>