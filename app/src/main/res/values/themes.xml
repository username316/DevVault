        <item name="colorPrimary">@color/lime</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_cream</item>
        <item name="android:colorBackground">@color/bg_cream</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:fontFamily">@font/space_grotesk</item>
    </style>

    <style name="Theme.DevVault" parent="Base.Theme.DevVault" />

    <style name="CardTitleStyle">
        <item name="android:fontFamily">@font/space_grotesk</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">-0.02</item>
